# Common
DATABASE_URL=postgres://user:pass@localhost:5432/robobounce2
NODE_ENV=development

# Worker only - 32 bytes base64 encoded
MASTER_ENCRYPTION_KEY=base64-32bytes-here

# Web (Next.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=base64-32bytes-here
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_IP_ALLOWLIST=
WEB_INTERNAL_TOKEN=base64-32bytes-here

# Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Worker
MEX_HOST=https://api.mexc.com
WORKER_ID=worker-1
DEPOSIT_POLL_INTERVAL_SEC=30
BOUNCE_LOOP_INTERVAL_SEC=5
RECONCILIATION_INTERVAL_SEC=300
SWEEP_CRON=0 3 * * *
LOG_RETENTION_DAYS=90
SLIPPAGE_MAX_PCT=1
DRY_RUN=false

# Optional - admin seed
ADMIN_TELEGRAM_ID=
ADMIN_TELEGRAM_USERNAME=
ADMIN_GOOGLE_EMAIL=
