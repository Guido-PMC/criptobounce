{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@rb/db": ["./packages/db/src"],
      "@rb/db/*": ["./packages/db/src/*"],
      "@rb/mex-client": ["./packages/mex-client/src"],
      "@rb/mex-client/*": ["./packages/mex-client/src/*"],
      "@rb/crypto": ["./packages/crypto/src"],
      "@rb/crypto/*": ["./packages/crypto/src/*"],
      "@rb/domain": ["./packages/domain/src"],
      "@rb/domain/*": ["./packages/domain/src/*"],
      "@rb/config": ["./packages/config/src"],
      "@rb/config/*": ["./packages/config/src/*"]
    }
  }
}
